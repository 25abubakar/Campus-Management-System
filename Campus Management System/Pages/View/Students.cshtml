@page
@model Campus_Management_System.Pages.View.StudentsModel
@{
    ViewData["Title"] = "Add Student";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Add New Student</h2>

    <form method="post">
        <div class="mb-3">
            <label>Name</label>
            <input asp-for="Student.Name" class="form-control" />
            <span asp-validation-for="Student.Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label>Email</label>
            <input asp-for="Student.Email" class="form-control" />
            <span asp-validation-for="Student.Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label>Phone</label>
            <input asp-for="Student.Phone" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Date Of Birth</label>
            <input asp-for="Student.DateOfBirth" type="date" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Gender</label><br />
            <label><input type="radio" asp-for="Student.Gender" value="Male" /> Male</label>
            <label><input type="radio" asp-for="Student.Gender" value="Female" /> Female</label>
            <label><input type="radio" asp-for="Student.Gender" value="Other" /> Other</label>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
    </form>
</div>