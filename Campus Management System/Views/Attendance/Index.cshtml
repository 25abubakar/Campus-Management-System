@model IEnumerable<Campus_Management_System.Models.Attendance>

@{
    ViewData["Title"] = "Attendance List";
}

<style>
    .table-attendance {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,.1);
    }

    .badge-present {
        background-color: #198754;
        color: white;
    }

    .badge-absent {
        background-color: #dc3545;
        color: white;
    }
</style>

<h2 class="mb-4">📋 Attendance Records</h2>

<table class="table table-striped table-hover table-attendance">
    <thead class="table-dark">
        <tr>
            <th>Student ID</th>
            <th>Student</th>
            <th>Course</th>
            <th>Date</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.StudentId</td>
                <td>@a.Student.Person.Name</td>
                <td>@a.Course.CourseName</td>
                <td>@a.Date.ToString("yyyy-MM-dd")</td>
                <td>
                    @if (a.IsPresent)
                    {
                        <span class="badge bg-success">Present</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Absent</span>
                    }
                </td>
                <td>
                    <a asp-action="Delete" asp-route-id="@a.AttendanceId"
                       class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<a asp-action="TakeAttendance" class="btn btn-primary mt-3">
    ➕ Mark New Attendance
</a>