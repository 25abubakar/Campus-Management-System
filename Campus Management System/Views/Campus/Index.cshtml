@{
    ViewData["Title"] = "Campuses";
}

<style>
    .campus-bg {
        background-image: url('/images/campus.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        padding: 30px;
    }

    .glass {
        background: rgba(255, 255, 255, 0.85);
        border-radius: 15px;
        padding: 25px;
        backdrop-filter: blur(5px);
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }

    .card h6 {
        font-weight: 600;
        opacity: 0.9;
    }

    .card h2 {
        font-weight: bold;
    }
</style>

<div class="campus-bg">

    <div class="container-fluid glass">

        <!-- Header -->
        <div class="mb-4">
            <h1 class="fs-3">📊 Campus Analytics</h1>
            <p class="text-muted">Welcome to Campus Management Analytics</p>
        </div>

        <!-- Cards -->
        <div class="row g-4">

            <div class="col-lg-3 col-md-6">
                <div class="card shadow-sm border-0 p-4 bg-primary text-white rounded-4">
                    <h6>Total Students</h6>
                    <h2>T.S = @ViewBag.TotalStudents</h2>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card shadow-sm border-0 p-4 bg-success text-white rounded-4">
                    <h6>Total Teachers</h6>
                    <h2>T.T = @ViewBag.TotalTeachers</h2>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card shadow-sm border-0 p-4 bg-warning text-white rounded-4">
                    <h6>Total Courses</h6>
                    <h2>TC = @ViewBag.TotalCourses</h2>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card shadow-sm border-0 p-4 bg-dark text-white rounded-4">
                    <h6>Today's Attendance</h6>
                    <h2>@ViewBag.TodayAttendancePercent%</h2>
                </div>
            </div>

        </div>

    </div>
</div>