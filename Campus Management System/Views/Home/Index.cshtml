@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .card-dashboard {
        border: none;
        border-radius: 15px;
        color: white;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,.15);
        transition: .3s;
    }
    .card-dashboard:hover {
        transform: translateY(-5px);
    }
    .bg-students { background: linear-gradient(45deg,#0d6efd,#00c6ff); }
    .bg-teachers { background: linear-gradient(45deg,#6610f2,#b5179e); }
    .bg-courses  { background: linear-gradient(45deg,#198754,#20c997); }
    .bg-attendance { background: linear-gradient(45deg,#fd7e14,#ffbe0b); }

    .big-number {
        font-size: 38px;
        font-weight: bold;
    }

    .quick-btn {
        border-radius: 10px;
        padding: 15px;
        font-weight: 600;
    }
</style>

<h2 class="mb-4">📊 Campus Dashboard</h2>

<div class="row g-4">

    <div class="col-md-3">
        <div class="card-dashboard bg-students">
            <h5>Total Students</h5>
            <div class="big-number">@ViewBag.TotalStudents</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card-dashboard bg-teachers">
            <h5>Total Teachers</h5>
            <div class="big-number">@ViewBag.TotalTeachers</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card-dashboard bg-courses">
            <h5>Total Courses</h5>
            <div class="big-number">@ViewBag.TotalCourses</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card-dashboard bg-attendance">
            <h5>Today's Attendance</h5>
            <div class="big-number">@ViewBag.TodayAttendancePercent%</div>
        </div>
    </div>

</div>

<hr class="my-5"/>

<h3 class="mb-4">⚡ Quick Actions</h3>

<div class="row g-4">

    <div class="col-md-3">
        <a asp-controller="Student" asp-action="Index" class="btn btn-primary w-100 quick-btn">
            ➕ Add Student
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Teacher" asp-action="Index" class="btn btn-success w-100 quick-btn">
            ➕ Add Teacher
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Course" asp-action="Index" class="btn btn-warning w-100 quick-btn">
            ➕ Add Course
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Attendance" asp-action="Index" class="btn btn-dark w-100 quick-btn">
            ✔ Mark Attendance
        </a>
    </div>

</div>