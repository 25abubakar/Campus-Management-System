@model Campus_Management_System.Models.StudentCreateViewModel

@{
    ViewData["Title"] = "Create Student";
}

<div class="container mt-4">

    <h2>Create Student Profile</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <!-- PERSON DROPDOWN -->
        <div class="mb-3">
            <label>Select Person</label>
            <select asp-for="Student.PersonId" class="form-control">
                <option value="">-- Select Student --</option>
                @foreach (var p in Model.StudentPersons)
                {
                    <option value="@p.PersonId">@p.Name</option>
                }
            </select>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label>Roll Number</label>
                <input asp-for="Student.RollNumber" class="form-control" />
            </div>

            <div class="col-md-4 mb-3">
                <label>Class</label>
                <input asp-for="Student.Class" class="form-control" />
            </div>

            <div class="col-md-4 mb-3">
                <label>Grade</label>
                <input asp-for="Student.Grade" class="form-control" />
            </div>
        </div>

        <hr />
        <h4>Assign Courses</h4>

        @foreach (var course in Model.Courses)
        {
            <div>
                <input type="checkbox" name="SelectedCourseIds" value="@course.CourseId" />
                @course.CourseName
            </div>
        }

        <br />
        <button class="btn btn-primary">Create Student</button>
    </form>

</div>