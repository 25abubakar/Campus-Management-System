@model List<Campus_Management_System.Models.StudentCourse>

@{
    ViewData["Title"] = "Student Courses";
}

<div class="container mt-4">

    <h2 class="text-center">Student Course Enrollments</h2>

    <table class="table table-bordered table-striped mt-4">
        <thead class="table-dark">
            <tr>
                <th>Student Name</th>
                <th>Email</th>
                <th>Roll No</th>
                <th>Class</th>
                <th>Course</th>
                <th>Credit Hours</th>
                <th>Fee</th>
                <th>Edit</th>
                <th>Delete</th> 
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Student?.Person?.Name</td>
                    <td>@item.Student?.Person?.Email</td>
                    <td>@item.Student?.RollNumber</td>
                    <td>@item.Student?.Class</td>
                    <td>@item.Course?.CourseName</td>
                    <td>@item.Course?.CreditHours</td>
                    <td>@item.Course?.Fee</td>
                    <td>
                        <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.CourseId">Edit</a>
                    </td>
                    <td>
                        <a class="btn btn-sm btn-danger" asp-action="Delete"
                               asp-route-studentId="@item.StudentId"
                               asp-route-courseId="@item.CourseId"
                            onclick="return confirm('Are you sure you want to delete this person?');">Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>