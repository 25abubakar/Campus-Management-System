@model List<Campus_Management_System.Models.TeacherCourse>

@{
    ViewData["Title"] = "Teacher Courses";
}

<div class="container mt-4">

    <h2 class="text-center">Teacher Course Assignments</h2>

    <table class="table table-bordered table-striped mt-4">
        <thead class="table-dark">
            <tr>
                <th>Teacher Name</th>
                <th>Email</th>
                <th>Qualification</th>
                <th>Salary</th>
                <th>Course Name</th>
                <th>Credit Hours</th>
                <th>Fee</th>
                <th>Update</th>
                <th>Delete</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Teacher?.Person?.Name</td>
                    <td>@item.Teacher?.Person?.Email</td>
                    <td>@item.Teacher?.Qualification</td>
                    <td>@item.Teacher?.Salary</td>
                    <td>@item.Course?.CourseName</td>
                    <td>@item.Course?.CreditHours</td>
                    <td>@item.Course?.Fee</td>
                    <td>
                        <a class="btn btn-sm btn-warning"
                               asp-action="Edit"
                               asp-route-teacherId="@item.TeacherId"
                               asp-route-courseId="@item.CourseId">
                            Edit
                        </a>
                    </td>
                    <td>
                        <a class="btn btn-sm btn-danger" asp-action="Delete"
                               asp-route-teacherId="@item.TeacherId"
                               asp-route-courseId="@item.CourseId"
                            onclick="return confirm('Are you sure you want to delete this assignment?');">Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>